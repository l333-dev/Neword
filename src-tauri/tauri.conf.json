{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Document Editor",
  "version": "0.1.0",
  "identifier": "dev.local.personal-doc-editor",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Personal Document Editor",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "fileAssociations": [
      {
        "ext": ["neword"],
        "name": "Neword Project",
        "description": "Personal Document Editor project",
        "mimeType": "application/x-neword-project",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "linux/desktop-template.desktop",
        "files": {
          "/usr/share/mime/packages/dev.local.personal-doc-editor.neword.xml": "linux/dev.local.personal-doc-editor.neword.xml"
        }
      },
      "rpm": {
        "desktopTemplate": "linux/desktop-template.desktop",
        "files": {
          "/usr/share/mime/packages/dev.local.personal-doc-editor.neword.xml": "linux/dev.local.personal-doc-editor.neword.xml"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
