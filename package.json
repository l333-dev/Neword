{
  "name": "personal-doc-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tiptap/extension-image": "3.27.4",
    "@tiptap/extension-link": "3.27.4",
    "@tiptap/extension-table": "3.27.4",
    "@tiptap/extension-table-cell": "3.27.4",
    "@tiptap/extension-table-header": "3.27.4",
    "@tiptap/extension-table-row": "3.27.4",
    "@tiptap/extension-text-align": "3.27.4",
    "@tiptap/extension-underline": "3.27.4",
    "@tiptap/core": "3.27.4",
    "@tiptap/react": "3.27.4",
    "@tiptap/starter-kit": "3.27.4",
    "docx": "9.7.1",
    "dompurify": "3.4.12",
    "jszip": "3.10.1",
    "mammoth": "1.12.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
